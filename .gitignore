# ========================
# MONOREPO ROOT .gitignore
# ========================

# --- General OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Passwords & Secrets (CRITICAL) ---
.env
.env.*
!.env.example
*.pem

# ========================
# FRONTEND (Next.js / Node)
# ========================
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js / TypeScript cache
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.vercel/

# ========================
# BACKEND (Python / FastAPI)
# ========================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.so

# Virtual Environments
backend/venv/
backend/env/
backend/.venv/
backend/ENV/

# Distribution / Packaging
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/

# Testing
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/
node_modules/