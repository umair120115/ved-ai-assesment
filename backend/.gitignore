# backend/.gitignore

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Virtual Environments
venv/
env/
.env_python/
.venv/
ENV/
env.bak/
venv.bak/

# Local Environment Variables (CRITICAL: Do not commit secrets)
.env
.env.*

# Docker
.dockerignore
docker-compose.override.yml

# IDEs and Editors
.idea/
.vscode/
*.swp
*.swo
.DS_Store

# Pytest / Coverage
.pytest_cache/
.coverage
htmlcov/

# Logs
logs/
*.log



# ========================
# MONOREPO ROOT .gitignore
# ========================

# --- General OS & IDE ---
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*.swo

# --- Passwords & Secrets (CRITICAL) ---
.env
.env.*
!.env.example
*.pem

# ========================
# FRONTEND (Next.js / Node)
# ========================
frontend/node_modules/
frontend/.pnp
frontend/.pnp.js
frontend/.next/
frontend/out/
frontend/build/
frontend/coverage/

# npm / yarn / pnpm logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# Next.js / TypeScript cache
frontend/*.tsbuildinfo
frontend/next-env.d.ts
frontend/.vercel/

# ========================
# BACKEND (Python / FastAPI)
# ========================
backend/__pycache__/
backend/*.py[cod]
backend/*$py.class
backend/*.so

# Virtual Environments
backend/venv/
backend/env/
backend/.venv/
backend/ENV/

# Distribution / Packaging
backend/build/
backend/dist/
backend/*.egg-info/
backend/.eggs/

# Testing
backend/.pytest_cache/
backend/.coverage
backend/htmlcov/